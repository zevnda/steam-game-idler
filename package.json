{
  "name": "steam-game-idler",
  "version": "6.0.7",
  "description": "Farm trading cards, manage achievements, and boost playtime effortlessly with Steam Game Idler",
  "author": "zevnda",
  "license": "Elastic-2.0",
  "private": true,
  "workspaces": [
    "docs"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:docs": "pnpm --filter steam-game-idler-docs dev",
    "dev:all": "pnpm td & pnpm --filter steam-game-idler-docs dev",
    "pub:docs": "pnpm --filter steam-game-idler-docs pub",
    "build": "next build",
    "build:docs": "pnpm --filter steam-game-idler-docs build",
    "build:all": "pnpm build && pnpm build:docs",
    "build:libs": "dotnet publish ./libs/SteamUtility/SteamUtility.csproj -c Release -r win-x64 --self-contained true -p:PublishSingleFile=true -p:PublishTrimmed=true -p:DebugType=none -o ./src-tauri/libs/",
    "start": "next start",
    "start:docs": "pnpm --filter steam-game-idler-docs start",
    "lint": "eslint .",
    "lint:docs": "pnpm --filter steam-game-idler-docs lint",
    "lint:all": "pnpm lint && pnpm lint:docs",
    "i18n:check": "node scripts/check-i18n.mjs",
    "tauri": "tauri",
    "prepare": "husky",
    "prettier": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "pretd": "node scripts/ensure-libs-built.mjs",
    "td": "tauri dev",
    "tb": "tauri build",
    "dd": "pnpm --filter steam-game-idler-docs dev",
    "main": "git checkout main && git pull && git fetch -p"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@heroui/react": "^3.2.2",
    "@heroui/styles": "^3.2.2",
    "@internationalized/date": "^3.12.2",
    "@tauri-apps/api": "~2.11.1",
    "@tauri-apps/plugin-autostart": "~2.5.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "~2.7.2",
    "@tauri-apps/plugin-notification": "~2.3.3",
    "@tauri-apps/plugin-opener": "~2.5.4",
    "@tauri-apps/plugin-process": "~2.3.1",
    "@tauri-apps/plugin-updater": "~2.10.1",
    "@tauri-apps/plugin-window-state": "~2.4.1",
    "fuse.js": "^7.4.2",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "next": "^16.2.10",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.9",
    "react-icons": "^5.7.0",
    "react-window": "^2.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^9.39.5",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^9.39.5",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3"
  }
}
